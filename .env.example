# URL pública do site (canonical, Open Graph, sitemap).
# Versão de teste local (predefinição no código se omitido):
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Quando o site estiver no servidor de produção (também definir no painel Vercel/Netlify):
# NEXT_PUBLIC_SITE_URL=https://www.figueiral.pt

# Google Analytics 4 — Measurement ID (ex.: G-XXXXXXXXXX). Opcional; só activa GA4 com consentimento Analítica.
# NEXT_PUBLIC_GA4_ID=
